DATABASE_URL=postgresql+asyncpg://user:password@localhost:5435/legal_ai
REDIS_URL=redis://localhost:6379/0
LARAVEL_API_KEY=your-secret-key-here
ADILET_BASE_URL=https://adilet.zan.kz
PARSER_DELAY_SECONDS=2

# LLM провайдер: groq | openai | ollama
LLM_PROVIDER=groq

GROQ_API_KEY=your-groq-key-here
GROQ_API_KEY_2=
GROQ_API_KEY_3=

OPENAI_API_KEY=your-openai-key-here
OPENAI_API_KEY_2=
OPENAI_API_KEY_3=

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Логирование SQL-запросов (true только для отладки)
DB_ECHO=false
